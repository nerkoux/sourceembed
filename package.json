{
	"name": "@letsroti/sourceembed",
	"version": "1.0.3",
	"description": "Store embed JSON to Cloudflare R2 and return a public URL",
	"main": "dist/index.js",
	"module": "dist/index.mjs",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			}
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"lint": "eslint src --fix",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "npm run build"
	},
	"keywords": [
		"s3-compatible",
		"cloudflare-r2",
		"json-hosting",
		"raw-text-storage",
		"public-url-storage"
	],
	"license": "MIT",
	"dependencies": {
		"@aws-sdk/client-s3": "^3.700.0"
	},
	"devDependencies": {
		"@types/node": "^25.4.0",
		"tsup": "^8.0.0",
		"typescript": "^5.5.0"
	},
	"engines": {
		"node": ">=18.0.0"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/letsroti/sourceembed.git"
	},
	"bugs": {
		"url": "https://github.com/letsroti/sourceembed/issues"
	},
	"homepage": "https://github.com/letsroti/sourceembed#readme"
}
